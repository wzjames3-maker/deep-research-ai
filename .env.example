# DeepResearch Agent — 环境变量配置
# 复制此文件为 .env 并填写实际值: cp .env.example .env

# ============================================================
# 数据库
# docker-compose 会自动从 POSTGRES_* 构造 DATABASE_URL。
# 本地开发时取消注释并填写:
DATABASE_URL=postgresql+asyncpg://deepresearch:CHANGE_ME_POSTGRES_PASSWORD@localhost:5432/deepresearch
# ============================================================
POSTGRES_USER=deepresearch
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=deepresearch

# ============================================================
# JWT 认证
# ============================================================
# 至少 32 字符随机字符串，用于签名 JWT Token
# 生成方式: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=86400
JWT_REMEMBER_ME_EXPIRES_IN=604800

# ============================================================
# bcrypt
# ============================================================
BCRYPT_ROUNDS=12

# ============================================================
# LLM 配置 (OpenAI Chat Completion 协议兼容)
# ============================================================
LLM_API_KEY=CHANGE_ME_LLM_API_KEY
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TIMEOUT=30

# ============================================================
# Brave Search API (MCP 搜索源 — 用于 brave-mcp 服务)
# ============================================================
# 免费获取: https://brave.com/search/api/
BRAVE_API_KEY=CHANGE_ME_BRAVE_API_KEY
BRAVE_MCP_URL=http://brave-mcp:3000
MCP_TIMEOUT=30
SUB_AGENT_TIMEOUT=180

# ============================================================
# 备用搜索源 (可选)
# ============================================================
# TAVILY_API_KEY=

# ============================================================
# 日志
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=console

# ============================================================
# 服务端口
# ============================================================
APP_PORT=8001
BRAVE_MCP_PORT=3000
NGINX_PORT=80
DB_PORT=5432
